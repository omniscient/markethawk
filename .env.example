# Stock Scanner System - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: Polygon.io API Key
# =============================================================================
# Get your API key from: https://polygon.io/dashboard
POLYGON_API_KEY=your_polygon_api_key_here

# =============================================================================
# OPTIONAL: Database Configuration
# =============================================================================
# Uncomment and modify if you want to use a different database
# Default: postgresql://postgres:stockscanner123@postgres:5432/stockscanner
# DATABASE_URL=postgresql://user:password@host:5432/database

# =============================================================================
# OPTIONAL: Redis Configuration
# =============================================================================
# Uncomment and modify if you want to use a different Redis instance
# Default: redis://redis:6379/0
# REDIS_URL=redis://host:6379/0

# =============================================================================
# OPTIONAL: Environment Settings
# =============================================================================
# Options: development, staging, production
# Default: development
# ENVIRONMENT=development

# =============================================================================
# OPTIONAL: Security
# =============================================================================
# Secret key for JWT tokens and sessions
# Generate a secure random string for production
# SECRET_KEY=your_secret_key_here

# =============================================================================
# OPTIONAL: Logging
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# =============================================================================
# OPTIONAL: Interactive Brokers (IBKR) Configuration
# =============================================================================
# Requires TWS or IB Gateway running locally with API connections enabled.
# TWS live port: 7496 | TWS paper: 7497
# IB Gateway live: 4001 | IB Gateway paper: 4002
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7496
# IBKR_CLIENT_ID=10
