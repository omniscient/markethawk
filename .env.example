# Stock Scanner System - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED: Polygon.io API Key
# =============================================================================
# Get your API key from: https://polygon.io/dashboard
# Startup validation will fail with a clear error if this is missing or empty.
POLYGON_API_KEY=your_polygon_api_key_here

# =============================================================================
# REQUIRED: Database Configuration
# =============================================================================
# Decomposed credentials (used by the postgres container).
# Change these from the defaults before deploying!
POSTGRES_DB=stockscanner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_db_password

# Full connection URL referenced by backend/celery services.
# Must stay in sync with the three variables above.
# Startup validation will fail with a clear error if this is missing or has a non-postgresql scheme.
DATABASE_URL=postgresql://postgres:change_me_db_password@postgres:5432/stockscanner

# =============================================================================
# REQUIRED: Redis Authentication
# =============================================================================
# Password for the Redis container (requirepass). Set before first docker compose up.
# Change this from the default — any process on the Docker network can connect to Redis.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=change_me_redis_password

# REDIS_URL is constructed automatically from REDIS_PASSWORD by docker-compose.
# Override only if connecting to an external Redis instance:
# REDIS_URL=redis://:your_password@host:6379/0

# =============================================================================
# OPTIONAL: Environment Settings
# =============================================================================
# Options: development, staging, production
# Default: development
# ENVIRONMENT=development

# =============================================================================
# REQUIRED: Security
# =============================================================================
# Secret key for JWT tokens and sessions.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# =============================================================================
# REQUIRED: Authentication (JWT)
# =============================================================================
# MANDATORY — startup validation will fail if this is missing or shorter than 32 chars.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# OPTIONAL: CORS Origins
# =============================================================================
# JSON array of allowed frontend origins.
# Default: ["http://localhost:3333"]
# CORS_ORIGINS=["http://localhost:3333","https://your-domain.com"]

# =============================================================================
# REQUIRED: pgAdmin Credentials
# =============================================================================
# Admin login for the pgAdmin web UI (http://localhost:5050).
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me_pgadmin_password

# =============================================================================
# REQUIRED: Seq Admin Password Hash
# =============================================================================
# Seq (http://localhost:5380) requires a bcrypt hash for the initial admin
# password so it starts with authentication enabled.
# Generate with:  echo 'YourPassword' | docker run --rm -i datalust/seq config hash
# Then paste the full hash string (begins with $2a$) as the value below.
SEQ_ADMIN_PASSWORD_HASH=

# =============================================================================
# REQUIRED: Flower Basic Auth
# =============================================================================
# Basic auth credentials for the Flower Celery monitoring UI (http://localhost:5555).
# Flower reads FLOWER_BASIC_AUTH automatically from the environment.
# Format: user:password
FLOWER_BASIC_AUTH=admin:change_me_flower_password

# =============================================================================
# OPTIONAL: Database Backup (db-backup sidecar)
# =============================================================================
# Directory on the Docker host where backups are written (bind-mounted into container).
# Default: /var/lib/markethawk/backups
# BACKUP_DIR=/var/lib/markethawk/backups
#
# Number of days to retain backup files before rotating.
# Default: 30
# BACKUP_RETENTION_DAYS=30
#
# Cron schedule for automatic backups (supercronic syntax, UTC).
# Default: daily at 3 AM UTC
# BACKUP_SCHEDULE=0 3 * * *

# =============================================================================
# OPTIONAL: Rate Limiting
# =============================================================================
# Set to false to disable API rate limiting (useful during local development).
# Default: true
RATE_LIMITING_ENABLED=true

# =============================================================================
# OPTIONAL: Logging
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
# LOG_LEVEL=INFO

# =============================================================================
# OPTIONAL: Interactive Brokers (IBKR) Configuration
# =============================================================================
# Requires TWS or IB Gateway running locally with API connections enabled.
# TWS live port: 7496 | TWS paper: 7497
# IB Gateway live: 4001 | IB Gateway paper: 4002
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7496
# IBKR_CLIENT_ID=10

# =============================================================================
# OPTIONAL: Alerting System Configuration
# =============================================================================

# Gmail SMTP (Use an App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_gmail_app_password
# SMTP_FROM_EMAIL=MarketHawk Alerts <your_email@gmail.com>

# Web Push / VAPID (Browser Push Notifications)
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
# VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# =============================================================================
# OPTIONAL: Dark Factory (Autonomous Development Agent)
# =============================================================================
# Required for running the dark-factory container.
# Anthropic API key for Claude Code:
# ANTHROPIC_API_KEY=sk-ant-...
#
# GitHub Personal Access Token (fine-grained, repo scope for omniscient/markethawk):
# GH_TOKEN=ghp_...
#
# These should also be added to .archon/.env (which is gitignored).

# =============================================================================
# Tweet Monitor Microservice
# =============================================================================
# Cookie-based X (Twitter) authentication — rotate manually ~every 30 days.
# Obtain from your browser's DevTools after logging into x.com:
#   auth_token cookie value:
X_AUTH_TOKEN=
#   ct0 cookie value (CSRF token):
X_CSRF_TOKEN=

# Classification & browser tunables (defaults shown)
PROMOTION_THRESHOLD=0.7
BROWSER_MAX_AGE_MINUTES=30
BROWSER_MAX_MEMORY_MB=512
POLL_TIMEOUT_SECONDS=25

# =============================================================================
# OPTIONAL: Frontend API Base URL
# =============================================================================
# Overrides the default versioned API base used by the React frontend.
# Default: /api/v1 (versioned — leave unset unless you have a specific reason)
# VITE_API_BASE_URL=/api/v1

# =============================================================================
# Monitoring (Grafana)
# =============================================================================
# Admin password for the Grafana UI (http://localhost:3001, login: admin).
# If not set, defaults to "admin" (change this in production).
GRAFANA_ADMIN_PASSWORD=changeme
