FROM alpine:3.19@sha256:6baf43584bcb78f2e5847d1de515f23499913ac9f12bdf834811a3145eb11ca1

# Install postgresql15-client and curl
RUN apk add --no-cache postgresql15-client curl

# Install supercronic (arch-aware)
ARG SUPERCRONIC_VERSION=0.2.29
RUN ARCH=$(uname -m); \
    case "${ARCH}" in \
        x86_64)  SC_ARCH="linux-amd64" ;; \
        aarch64) SC_ARCH="linux-arm64" ;; \
        armv7l)  SC_ARCH="linux-arm" ;; \
        *)       echo "Unsupported architecture: ${ARCH}" && exit 1 ;; \
    esac; \
    wget -q "https://github.com/aptible/supercronic/releases/download/v${SUPERCRONIC_VERSION}/supercronic-${SC_ARCH}" \
         -O /usr/local/bin/supercronic && \
    chmod +x /usr/local/bin/supercronic

# Copy scripts
COPY scripts/backup.sh /scripts/backup.sh
COPY scripts/backup-entrypoint.sh /entrypoint.sh
RUN chmod +x /scripts/backup.sh /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
